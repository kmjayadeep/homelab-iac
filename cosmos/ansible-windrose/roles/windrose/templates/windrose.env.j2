# Container identity and image
# Keep HOSTNAME=localhost for Windrose ICE compatibility. Change only if DNS resolution is known to work.
CONTAINER_NAME={{ windrose_container_name }}
HOSTNAME={{ windrose_container_hostname }}
IMAGE_REPOSITORY={{ windrose_image_repository }}
IMAGE_TAG={{ windrose_image_tag }}

# Host permissions
PUID={{ windrose_container_puid }}
PGID={{ windrose_container_pgid }}

# Steam / game
STEAM_LOGIN={{ windrose_steam_login }}
STEAM_PASS={{ windrose_steam_pass }}
WINDROSE_APP_ID={{ windrose_app_id }}
UPDATE_ON_START={{ windrose_update_on_start | bool | lower }}
GENERATE_SETTINGS={{ windrose_generate_settings | bool | lower }}

# ServerDescription.json patching
INVITE_CODE={{ windrose_invite_code }}
SERVER_NAME={{ windrose_server_name }}
SERVER_NOTE={{ windrose_server_note }}
SERVER_PASSWORD={{ windrose_server_password }}
MAX_PLAYERS={{ windrose_max_players }}
P2P_PROXY_ADDRESS={{ windrose_p2p_proxy_address }}

# Direct connection
USE_DIRECT_CONNECTION={{ windrose_use_direct_connection | bool | lower }}
DIRECT_CONNECTION_SERVER_PORT={{ windrose_direct_connection_server_port }}
DIRECT_CONNECTION_PROXY_ADDRESS={{ windrose_direct_connection_proxy_address }}
USER_SELECTED_REGION={{ windrose_user_selected_region }}

# Notifications
NOTIFY_PROVIDER={{ windrose_notify_provider }}
DISCORD_WEBHOOK_URL={{ windrose_discord_webhook_url }}
GOTIFY_URL={{ windrose_gotify_url }}
GOTIFY_TOKEN={{ windrose_gotify_token }}
GOTIFY_PRIORITY={{ windrose_gotify_priority }}

# Backups
BACKUP_DIR={{ windrose_backup_dir }}
BACKUP_RETENTION_DAYS={{ windrose_backup_retention_days }}
BACKUP_SCOPE={{ windrose_backup_scope }}
BACKUP_FORMAT={{ windrose_backup_format }}
BACKUP_NOTIFY_SUCCESS={{ windrose_backup_notify_success | bool | lower }}
BACKUP_NOTIFY_FAIL={{ windrose_backup_notify_fail | bool | lower }}
BACKUP_DISCORD_UPLOAD={{ windrose_backup_discord_upload | bool | lower }}

# Networking
PORT={{ windrose_port }}
QUERYPORT={{ windrose_query_port }}
MULTIHOME={{ windrose_multihome }}
